{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListS3ScriptFiles",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::greatestbucketever",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "websocket_folder",
            "websocket_folder/*"
          ]
        }
      }
    },
    {
      "Sid": "GetFiles",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::greatestbucketever/websocket_folder/*"
      ]
    }
  ]
}